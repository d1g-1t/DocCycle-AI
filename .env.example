APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8100

POSTGRES_HOST=postgres
POSTGRES_PORT=5433
POSTGRES_DB=contractforge
POSTGRES_USER=cf
POSTGRES_PASSWORD=cf-secret-2026

REDIS_HOST=redis
REDIS_PORT=6380
REDIS_PASSWORD=cf-redis-secret

MINIO_ENDPOINT=minio:9010
MINIO_PUBLIC_ENDPOINT=http://localhost:9010
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio-secret-2026
MINIO_BUCKET_CONTRACTS=contractforge-files

OLLAMA_BASE_URL=http://ollama:11435
OLLAMA_CHAT_MODEL=qwen2.5:14b
OLLAMA_EMBED_MODEL=nomic-embed-text

PASETO_SECRET_KEY=replace-with-32-byte-base64-secret-key
ACCESS_TOKEN_TTL_MINUTES=30
REFRESH_TOKEN_TTL_DAYS=14

OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo:4317
OTEL_SERVICE_NAME=contractforge-api

LANGFUSE_HOST=http://langfuse:3000
LANGFUSE_PUBLIC_KEY=public-key
LANGFUSE_SECRET_KEY=secret-key
LANGFUSE_SECRET=replace-with-random
LANGFUSE_SALT=replace-with-random

ENABLE_LOG_MASKING=true
CORS_ALLOW_ORIGINS=http://localhost:3002,http://localhost:8100
AI_REVIEW_TIMEOUT_SECONDS=90
HYBRID_SEARCH_ENABLED=true
SEMANTIC_SEARCH_TOP_K=8
SEMANTIC_SEARCH_MIN_SCORE=0.60
RENEWAL_ALERT_DAYS_BEFORE=30
WORKFLOW_SLA_WARNING_MINUTES=60
